ï»¿[{"filePath":"C:\\Users\\amjad\\Desktop\\ZeroTrustBounties\\app\\hacker\\page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\amjad\\Desktop\\ZeroTrustBounties\\app\\sponsor\\page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'parseUnits' is defined but never used.","line":8,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":8,"endColumn":20,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"parseUnits"},"fix":{"range":[350,361],"text":""},"desc":"Remove unused variable \"parseUnits\"."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'formatUnits' is defined but never used.","line":8,"column":22,"nodeType":"Identifier","messageId":"unusedVar","endLine":8,"endColumn":33,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"formatUnits"},"fix":{"range":[341,389],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'result' is assigned a value but never used.","line":138,"column":14,"nodeType":"Identifier","messageId":"unusedVar","endLine":138,"endColumn":20}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client'\r\n\r\nimport { useState } from 'react'\r\nimport { useAccount, useConnect, useDisconnect, useChainId } from 'wagmi'\r\nimport { generateECIESKeyPair, type ECIESKeyPair } from '@/lib/ecies'\r\nimport { uploadWASM, uploadDualBitmap, computeFileCID, computeBytesCID } from '@/lib/ipfs'\r\nimport useZTBContract from '@/hooks/useZTBContract'\r\nimport { parseUnits, formatUnits } from 'viem'\r\nimport { type Domain, type VerificationMode, DOMAIN_LABELS, MODE_LABELS } from '@/lib/abi/ZTBEscrow.abi'\r\n\r\n// Ă”Ă¶Ă‡Ă”Ă¶Ă‡ Types Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡\r\n\r\ninterface FinancialConfig {\r\n  authorizedIndices: number[]   // max 8 indices\r\n  maxDeltaPct:       number     // max 20%\r\n}\r\n\r\ninterface SponsorState {\r\n  // â”œĂ«tape 1 Ă”Ă‡Ă¶ WASM\r\n  wasmFile:       File | null\r\n  wasmCID:        string\r\n  wasmIPFSUrl:    string\r\n  wasmUploading:  boolean\r\n\r\n  // â”œĂ«tape 2 Ă”Ă‡Ă¶ Dual bitmap\r\n  bitmapAFile:    File | null\r\n  bitmapBFile:    File | null\r\n  bitmapACID:     string\r\n  bitmapBCID:     string\r\n  bitmapACoverage: number\r\n  bitmapBCoverage: number\r\n  bitmapUploading: boolean\r\n\r\n  // â”œĂ«tape 3 Ă”Ă‡Ă¶ Config\r\n  domain:         Domain\r\n  mode:           VerificationMode\r\n  financialConfig: FinancialConfig\r\n\r\n  // â”œĂ«tape 4 Ă”Ă‡Ă¶ ECIES\r\n  keyPair:        ECIESKeyPair | null\r\n  keySaved:       boolean\r\n\r\n  // â”œĂ«tape 5 Ă”Ă‡Ă¶ Reward\r\n  rewardUsdt:     string\r\n  rewardFloorUsdt: string\r\n\r\n  // â”œĂ«tape 6 Ă”Ă‡Ă¶ Tx\r\n  txHash:         string\r\n  txStatus:       'idle' | 'pending' | 'success' | 'error'\r\n  txError:        string\r\n}\r\n\r\n// Ă”Ă¶Ă‡Ă”Ă¶Ă‡ Composant principal Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡\r\n\r\nexport default function SponsorPage() {\r\n  const { address, isConnected } = useAccount()\r\n  const { connect, connectors }  = useConnect()\r\n  const { disconnect }           = useDisconnect()\r\n  const chainId                  = useChainId()\r\n  const isOnSepolia              = chainId === 11155111\r\n  const metaMaskConnector =\r\n    connectors.find(c => c.name.toLowerCase().includes('metamask')) ?? connectors[0]\r\n\r\n  const { createBounty, isPending, isSuccess, isError, error, txHash } = useZTBContract()\r\n\r\n  const [state, setState] = useState<SponsorState>({\r\n    wasmFile: null, wasmCID: '', wasmIPFSUrl: '', wasmUploading: false,\r\n    bitmapAFile: null, bitmapBFile: null,\r\n    bitmapACID: '', bitmapBCID: '',\r\n    bitmapACoverage: 0, bitmapBCoverage: 0, bitmapUploading: false,\r\n    domain: 0, mode: 0,\r\n    financialConfig: { authorizedIndices: [], maxDeltaPct: 10 },\r\n    keyPair: null, keySaved: false,\r\n    rewardUsdt: '', rewardFloorUsdt: '',\r\n    txHash: '', txStatus: 'idle', txError: '',\r\n  })\r\n\r\n  const [globalError, setGlobalError] = useState<string | null>(null)\r\n\r\n  // Ă”Ă¶Ă‡Ă”Ă¶Ă‡ â”œĂ«tape 1 Ă”Ă‡Ă¶ Upload WASM Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡\r\n\r\n  async function handleWASMUpload(e: React.ChangeEvent<HTMLInputElement>) {\r\n    const file = e.target.files?.[0]\r\n    if (!file) return\r\n    if (!file.name.endsWith('.wasm')) {\r\n      setGlobalError('Fichier invalide Ă”Ă‡Ă¶ sâ”œÂ®lectionnez un fichier .wasm')\r\n      return\r\n    }\r\n    setState(s => ({ ...s, wasmFile: file, wasmUploading: true }))\r\n    setGlobalError(null)\r\n    try {\r\n      const [result, cid] = await Promise.all([\r\n        uploadWASM(file),\r\n        computeFileCID(file),\r\n      ])\r\n      setState(s => ({\r\n        ...s,\r\n        wasmCID: cid,\r\n        wasmIPFSUrl: result.url,\r\n        wasmUploading: false,\r\n      }))\r\n    } catch (e) {\r\n      setGlobalError('Upload WASM â”œÂ®chouâ”œÂ® : ' + String(e))\r\n      setState(s => ({ ...s, wasmUploading: false }))\r\n    }\r\n  }\r\n\r\n  // Ă”Ă¶Ă‡Ă”Ă¶Ă‡ â”œĂ«tape 2 Ă”Ă‡Ă¶ Upload dual bitmap Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡\r\n\r\n  async function handleBitmapUpload(\r\n    e: React.ChangeEvent<HTMLInputElement>,\r\n    which: 'A' | 'B',\r\n  ) {\r\n    const file = e.target.files?.[0]\r\n    if (!file) return\r\n    const bytes = new Uint8Array(await file.arrayBuffer())\r\n    const coverage = Math.round((countBits(bytes) / (bytes.length * 8)) * 100)\r\n\r\n    if (which === 'A') {\r\n      setState(s => ({ ...s, bitmapAFile: file, bitmapACoverage: coverage }))\r\n    } else {\r\n      setState(s => ({ ...s, bitmapBFile: file, bitmapBCoverage: coverage }))\r\n    }\r\n  }\r\n\r\n  async function handleUploadBitmaps() {\r\n    if (!state.bitmapAFile || !state.bitmapBFile) {\r\n      setGlobalError('Sâ”œÂ®lectionnez les deux bitmaps A et B')\r\n      return\r\n    }\r\n    setState(s => ({ ...s, bitmapUploading: true }))\r\n    setGlobalError(null)\r\n    try {\r\n      const [bytesA, bytesB] = await Promise.all([\r\n        state.bitmapAFile.arrayBuffer().then(b => new Uint8Array(b)),\r\n        state.bitmapBFile.arrayBuffer().then(b => new Uint8Array(b)),\r\n      ])\r\n      const [result, cidA, cidB] = await Promise.all([\r\n        uploadDualBitmap(bytesA, bytesB),\r\n        computeBytesCID(bytesA),\r\n        computeBytesCID(bytesB),\r\n      ])\r\n      setState(s => ({\r\n        ...s,\r\n        bitmapACID: cidA,\r\n        bitmapBCID: cidB,\r\n        bitmapUploading: false,\r\n      }))\r\n    } catch (e) {\r\n      setGlobalError('Upload bitmaps â”œÂ®chouâ”œÂ® : ' + String(e))\r\n      setState(s => ({ ...s, bitmapUploading: false }))\r\n    }\r\n  }\r\n\r\n  // Ă”Ă¶Ă‡Ă”Ă¶Ă‡ â”œĂ«tape 4 Ă”Ă‡Ă¶ ECIES Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡\r\n\r\n  function handleGenerateKeys() {\r\n    try {\r\n      const pair = generateECIESKeyPair()\r\n      setState(s => ({ ...s, keyPair: pair, keySaved: false }))\r\n    } catch (e) {\r\n      setGlobalError('Erreur gâ”œÂ®nâ”œÂ®ration clâ”œÂ®s : ' + String(e))\r\n    }\r\n  }\r\n\r\n  function handleDownloadKey() {\r\n    if (!state.keyPair) return\r\n    const blob = new Blob([state.keyPair.privateKeyHex], { type: 'text/plain' })\r\n    const url  = URL.createObjectURL(blob)\r\n    const a    = document.createElement('a')\r\n    a.href     = url\r\n    a.download = 'ztb_private_key.txt'\r\n    a.click()\r\n    URL.revokeObjectURL(url)\r\n    setState(s => ({ ...s, keySaved: true }))\r\n  }\r\n\r\n  // Ă”Ă¶Ă‡Ă”Ă¶Ă‡ â”œĂ«tape 5 Ă”Ă‡Ă¶ Reward Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡\r\n\r\n  function handleRewardChange(value: string) {\r\n    const floor = state.mode === 1\r\n      ? (parseFloat(value) * 0.7).toFixed(2)\r\n      : value\r\n    setState(s => ({ ...s, rewardUsdt: value, rewardFloorUsdt: floor }))\r\n  }\r\n\r\n  // Ă”Ă¶Ă‡Ă”Ă¶Ă‡ â”œĂ«tape 6 Ă”Ă‡Ă¶ createBounty() Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡\r\n\r\n  async function handleCreateBounty() {\r\n    setGlobalError(null)\r\n\r\n    if (!state.wasmCID)          return setGlobalError('Uploadez le WASM d\\'abord')\r\n    if (!state.bitmapACID)       return setGlobalError('Uploadez les bitmaps d\\'abord')\r\n    if (!state.keyPair)          return setGlobalError('Gâ”œÂ®nâ”œÂ®rez la clâ”œÂ® ECIES d\\'abord')\r\n    if (!state.keySaved)         return setGlobalError('Tâ”œÂ®lâ”œÂ®chargez la clâ”œÂ® privâ”œÂ®e d\\'abord')\r\n    if (!state.rewardUsdt)       return setGlobalError('Dâ”œÂ®finissez la râ”œÂ®compense USDT')\r\n\r\n    try {\r\n      await createBounty({\r\n        targetCID:           state.wasmCID as `0x${string}`,\r\n        staticPropsHash:     '0x' + '0'.repeat(64) as `0x${string}`, // Youssef livrera\r\n        baselineMerkleRootA: '0x' + '0'.repeat(64) as `0x${string}`, // Youssef livrera\r\n        baselineMerkleRootB: '0x' + '0'.repeat(64) as `0x${string}`, // Youssef livrera\r\n        baselineHashA:       state.bitmapACID as `0x${string}`,\r\n        baselineHashB:       state.bitmapBCID as `0x${string}`,\r\n        financialConfigHash: '0x' + '0'.repeat(64) as `0x${string}`, // calculâ”œÂ® localement\r\n        domain:              state.domain,\r\n        mode:                state.mode,\r\n        extractionReceipt:   '0x' as `0x${string}`,                  // Youssef livrera\r\n        maxSteps:            1000000n,\r\n        eciesPublicKey:      state.keyPair.publicKeyHex as `0x${string}`,\r\n        rewardUsdt:          state.rewardUsdt,\r\n        rewardFloorUsdt:     state.rewardFloorUsdt || state.rewardUsdt,\r\n      })\r\n    } catch (e) {\r\n      setGlobalError('createBounty â”œÂ®chouâ”œÂ® : ' + String(e))\r\n    }\r\n  }\r\n\r\n  // Ă”Ă¶Ă‡Ă”Ă¶Ă‡ Utilitaire Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡\r\n\r\n  function countBits(bytes: Uint8Array): number {\r\n    return bytes.reduce((acc, b) => acc + popcount(b), 0)\r\n  }\r\n  function popcount(n: number): number {\r\n    let c = 0\r\n    while (n) { c += n & 1; n >>= 1 }\r\n    return c\r\n  }\r\n\r\n  // Ă”Ă¶Ă‡Ă”Ă¶Ă‡ Vâ”œÂ®rification complâ”œÂ®tude Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡\r\n\r\n  const step1Done = !!state.wasmCID\r\n  const step2Done = !!state.bitmapACID && !!state.bitmapBCID\r\n  const step3Done = true // toujours une valeur par dâ”œÂ®faut\r\n  const step4Done = !!state.keyPair && state.keySaved\r\n  const step5Done = !!state.rewardUsdt\r\n  const allDone   = step1Done && step2Done && step3Done && step4Done && step5Done\r\n\r\n  // Ă”Ă¶Ă‡Ă”Ă¶Ă‡ Render Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡\r\n\r\n  return (\r\n    <main className=\"app-shell\">\r\n      <div className=\"sponsor-wrap\">\r\n\r\n        {/* Header */}\r\n        <header className=\"glass-panel stagger-in sponsor-header\">\r\n          <div className=\"sponsor-header-top\">\r\n            <h1 className=\"hero-title title-gradient sponsor-title\">\r\n              Interface Sponsor\r\n            </h1>\r\n            <span className=\"status-chip ok\">V4.3 â”¬Ă€ Sepolia</span>\r\n          </div>\r\n          <p className=\"muted sponsor-subtitle\">\r\n            Crâ”œÂ®ez un bounty dâ”œÂ®centralisâ”œÂ® Ă”Ă‡Ă¶ verrouillez vos USDT, recevez les exploits chiffrâ”œÂ®s.\r\n          </p>\r\n        </header>\r\n\r\n        {/* Erreur globale */}\r\n        {globalError && (\r\n          <div className=\"glass-panel stagger-in\" style={{ padding: '14px 20px', borderColor: 'rgba(199,116,116,0.4)' }}>\r\n            <p className=\"error-note\">Ă”ĂœĂ¡Â´Â©Ă… {globalError}</p>\r\n          </div>\r\n        )}\r\n\r\n        {/* Ă”Ă¶Ă‡Ă”Ă¶Ă‡ â”œĂ«tape 0 Ă”Ă‡Ă¶ Wallet Ă”Ă¶Ă‡Ă”Ă¶Ă‡ */}\r\n        <section className=\"glass-panel stagger-in sponsor-step\">\r\n          <p className=\"step-title\">â”œĂ«tape 1 Ă”Ă‡Ă¶ Connexion Wallet</p>\r\n          {isConnected ? (\r\n            <div className=\"sponsor-col\">\r\n              <span className={`status-chip ${isOnSepolia ? 'ok' : 'bad'}`}>\r\n                {isOnSepolia ? 'Ă”Â£Ă  Sepolia' : 'Ă”Ă˜Ă® Passez sur Sepolia'}\r\n              </span>\r\n              <div className=\"mono-box address-text\">{address}</div>\r\n              <button onClick={() => disconnect()} className=\"app-btn danger fit-content\">\r\n                Dâ”œÂ®connecter\r\n              </button>\r\n            </div>\r\n          ) : (\r\n            <button\r\n              onClick={() => metaMaskConnector && connect({ connector: metaMaskConnector })}\r\n              className=\"app-btn primary fit-content\"\r\n              disabled={!metaMaskConnector}\r\n            >\r\n              Connecter MetaMask\r\n            </button>\r\n          )}\r\n        </section>\r\n\r\n        {isConnected && isOnSepolia && (\r\n          <>\r\n            {/* Ă”Ă¶Ă‡Ă”Ă¶Ă‡ â”œĂ«tape 1 Ă”Ă‡Ă¶ WASM Ă”Ă¶Ă‡Ă”Ă¶Ă‡ */}\r\n            <section className=\"glass-panel stagger-in delay-1 sponsor-step\">\r\n              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 16 }}>\r\n                <p className=\"step-title\" style={{ margin: 0 }}>â”œĂ«tape 2 Ă”Ă‡Ă¶ Upload WASM instrumentâ”œÂ®</p>\r\n                {step1Done && <span className=\"status-chip ok\">Ă”Â£Ă  Uploadâ”œÂ®</span>}\r\n              </div>\r\n\r\n              <label className=\"app-btn secondary fit-content\" style={{ cursor: 'pointer' }}>\r\n                {state.wasmUploading ? 'Upload en cours...' : 'Sâ”œÂ®lectionner .wasm'}\r\n                <input type=\"file\" accept=\".wasm\" onChange={handleWASMUpload} style={{ display: 'none' }} disabled={state.wasmUploading} />\r\n              </label>\r\n\r\n              {state.wasmFile && (\r\n                <div style={{ marginTop: 12, display: 'flex', flexDirection: 'column', gap: 8 }}>\r\n                  <p className=\"muted key-label\">Fichier</p>\r\n                  <div className=\"mono-box\" style={{ color: '#b8d6ea' }}>{state.wasmFile.name} Ă”Ă‡Ă¶ {(state.wasmFile.size / 1024).toFixed(1)} KB</div>\r\n                  {state.wasmCID && (\r\n                    <>\r\n                      <p className=\"muted key-label\">CIDv1 (targetCID on-chain)</p>\r\n                      <div className=\"mono-box pub-key\">{state.wasmCID}</div>\r\n                    </>\r\n                  )}\r\n                </div>\r\n              )}\r\n            </section>\r\n\r\n            {/* Ă”Ă¶Ă‡Ă”Ă¶Ă‡ â”œĂ«tape 2 Ă”Ă‡Ă¶ Dual Bitmap Ă”Ă¶Ă‡Ă”Ă¶Ă‡ */}\r\n            <section className=\"glass-panel stagger-in delay-1 sponsor-step\">\r\n              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 16 }}>\r\n                <p className=\"step-title\" style={{ margin: 0 }}>â”œĂ«tape 3 Ă”Ă‡Ă¶ Upload Dual Bitmap Baseline</p>\r\n                {step2Done && <span className=\"status-chip ok\">Ă”Â£Ă  Uploadâ”œÂ®</span>}\r\n              </div>\r\n\r\n              <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>\r\n                {/* Bitmap A */}\r\n                <div>\r\n                  <p className=\"muted key-label\">Bitmap A Ă”Ă‡Ă¶ Hash AFL XOR</p>\r\n                  <label className=\"app-btn secondary fit-content\" style={{ cursor: 'pointer', display: 'block' }}>\r\n                    {state.bitmapAFile ? state.bitmapAFile.name : 'Sâ”œÂ®lectionner baseline_a.bin'}\r\n                    <input type=\"file\" accept=\".bin\" onChange={e => handleBitmapUpload(e, 'A')} style={{ display: 'none' }} />\r\n                  </label>\r\n                  {state.bitmapAFile && (\r\n                    <div style={{ marginTop: 8 }}>\r\n                      <div style={{ background: 'rgba(11,22,36,0.76)', borderRadius: 8, padding: '6px 10px', marginBottom: 6 }}>\r\n                        <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>\r\n                          <span className=\"muted\" style={{ fontSize: '0.78rem' }}>Couverture A</span>\r\n                          <span style={{ fontSize: '0.78rem', color: state.bitmapACoverage >= 20 ? '#4ade80' : '#f87171', fontWeight: 700 }}>\r\n                            {state.bitmapACoverage}%\r\n                          </span>\r\n                        </div>\r\n                        <div style={{ background: 'rgba(255,255,255,0.08)', borderRadius: 4, height: 6 }}>\r\n                          <div style={{ width: `${Math.min(state.bitmapACoverage, 100)}%`, background: state.bitmapACoverage >= 20 ? '#4ade80' : '#f87171', height: 6, borderRadius: 4, transition: 'width 0.4s' }} />\r\n                        </div>\r\n                      </div>\r\n                      {state.bitmapACoverage < 20 && (\r\n                        <p className=\"error-note\">Ă”ĂœĂ¡Â´Â©Ă… Couverture insuffisante Ă”Ă‡Ă¶ minimum 20% requis</p>\r\n                      )}\r\n                    </div>\r\n                  )}\r\n                </div>\r\n\r\n                {/* Bitmap B */}\r\n                <div>\r\n                  <p className=\"muted key-label\">Bitmap B Ă”Ă‡Ă¶ Hash Knuth multiplicatif</p>\r\n                  <label className=\"app-btn secondary fit-content\" style={{ cursor: 'pointer', display: 'block' }}>\r\n                    {state.bitmapBFile ? state.bitmapBFile.name : 'Sâ”œÂ®lectionner baseline_b.bin'}\r\n                    <input type=\"file\" accept=\".bin\" onChange={e => handleBitmapUpload(e, 'B')} style={{ display: 'none' }} />\r\n                  </label>\r\n                  {state.bitmapBFile && (\r\n                    <div style={{ marginTop: 8 }}>\r\n                      <div style={{ background: 'rgba(11,22,36,0.76)', borderRadius: 8, padding: '6px 10px', marginBottom: 6 }}>\r\n                        <div style={{ display: 'flex', justifyContent: 'space-between', marginBottom: 4 }}>\r\n                          <span className=\"muted\" style={{ fontSize: '0.78rem' }}>Couverture B</span>\r\n                          <span style={{ fontSize: '0.78rem', color: state.bitmapBCoverage >= 20 ? '#4ade80' : '#f87171', fontWeight: 700 }}>\r\n                            {state.bitmapBCoverage}%\r\n                          </span>\r\n                        </div>\r\n                        <div style={{ background: 'rgba(255,255,255,0.08)', borderRadius: 4, height: 6 }}>\r\n                          <div style={{ width: `${Math.min(state.bitmapBCoverage, 100)}%`, background: state.bitmapBCoverage >= 20 ? '#4ade80' : '#f87171', height: 6, borderRadius: 4, transition: 'width 0.4s' }} />\r\n                        </div>\r\n                      </div>\r\n                      {state.bitmapBCoverage < 20 && (\r\n                        <p className=\"error-note\">Ă”ĂœĂ¡Â´Â©Ă… Couverture insuffisante Ă”Ă‡Ă¶ minimum 20% requis</p>\r\n                      )}\r\n                    </div>\r\n                  )}\r\n                </div>\r\n              </div>\r\n\r\n              {state.bitmapAFile && state.bitmapBFile && !step2Done && (\r\n                <button\r\n                  onClick={handleUploadBitmaps}\r\n                  className=\"app-btn secondary fit-content\"\r\n                  style={{ marginTop: 12 }}\r\n                  disabled={state.bitmapUploading || state.bitmapACoverage < 20 || state.bitmapBCoverage < 20}\r\n                >\r\n                  {state.bitmapUploading ? 'Upload en cours...' : 'Uploader les deux bitmaps'}\r\n                </button>\r\n              )}\r\n            </section>\r\n\r\n            {/* Ă”Ă¶Ă‡Ă”Ă¶Ă‡ â”œĂ«tape 3 Ă”Ă‡Ă¶ Domaine + Mode Ă”Ă¶Ă‡Ă”Ă¶Ă‡ */}\r\n            <section className=\"glass-panel stagger-in delay-2 sponsor-step\">\r\n              <p className=\"step-title\">â”œĂ«tape 4 Ă”Ă‡Ă¶ Configuration Oracle</p>\r\n\r\n              {/* Domaine */}\r\n              <div style={{ marginBottom: 20 }}>\r\n                <p className=\"muted key-label\">Domaine</p>\r\n                <div style={{ display: 'flex', gap: 10, flexWrap: 'wrap' }}>\r\n                  {([0, 1, 2] as Domain[]).map(d => (\r\n                    <button\r\n                      key={d}\r\n                      onClick={() => setState(s => ({ ...s, domain: d }))}\r\n                      className={`app-btn ${state.domain === d ? 'primary' : 'secondary'}`}\r\n                      style={{ minWidth: 140 }}\r\n                    >\r\n                      {DOMAIN_LABELS[d]}\r\n                    </button>\r\n                  ))}\r\n                </div>\r\n              </div>\r\n\r\n              {/* FinancialConfig si FINANCIAL */}\r\n              {state.domain === 0 && (\r\n                <div style={{ marginBottom: 20, padding: '14px', background: 'rgba(11,22,36,0.5)', borderRadius: 12, border: '1px solid rgba(123,151,186,0.2)' }}>\r\n                  <p className=\"muted key-label\" style={{ marginBottom: 8 }}>FinancialConfig Ă”Ă‡Ă¶ max 8 indices, delta Ă”Ă«Ă± 20%</p>\r\n                  <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>\r\n                    <div>\r\n                      <p className=\"muted\" style={{ fontSize: '0.8rem', marginBottom: 6 }}>Indices autorisâ”œÂ®s (sâ”œÂ®parâ”œÂ®s par virgule)</p>\r\n                      <input\r\n                        type=\"text\"\r\n                        placeholder=\"ex: 0,1,2,3\"\r\n                        className=\"mono-box\"\r\n                        style={{ width: '100%', color: '#b8d6ea', outline: 'none' }}\r\n                        onChange={e => {\r\n                          const indices = e.target.value.split(',').map(Number).filter(n => !isNaN(n)).slice(0, 8)\r\n                          setState(s => ({ ...s, financialConfig: { ...s.financialConfig, authorizedIndices: indices } }))\r\n                        }}\r\n                      />\r\n                    </div>\r\n                    <div>\r\n                      <p className=\"muted\" style={{ fontSize: '0.8rem', marginBottom: 6 }}>Delta maximum (%)</p>\r\n                      <input\r\n                        type=\"number\"\r\n                        min={1}\r\n                        max={20}\r\n                        value={state.financialConfig.maxDeltaPct}\r\n                        className=\"mono-box\"\r\n                        style={{ width: '100%', color: '#b8d6ea', outline: 'none' }}\r\n                        onChange={e => setState(s => ({ ...s, financialConfig: { ...s.financialConfig, maxDeltaPct: Math.min(20, parseInt(e.target.value) || 10) } }))}\r\n                      />\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              )}\r\n\r\n              {/* Mode */}\r\n              <div>\r\n                <p className=\"muted key-label\">Mode de vâ”œÂ®rification</p>\r\n                <div style={{ display: 'flex', gap: 10, flexWrap: 'wrap' }}>\r\n                  {([0, 1] as VerificationMode[]).map(m => (\r\n                    <button\r\n                      key={m}\r\n                      onClick={() => {\r\n                        setState(s => ({\r\n                          ...s,\r\n                          mode: m,\r\n                          rewardFloorUsdt: m === 1 && s.rewardUsdt ? (parseFloat(s.rewardUsdt) * 0.7).toFixed(2) : s.rewardUsdt,\r\n                        }))\r\n                      }}\r\n                      className={`app-btn ${state.mode === m ? 'primary' : 'secondary'}`}\r\n                      style={{ minWidth: 200 }}\r\n                    >\r\n                      {m === 0 ? 'STRICT Ă”Ă‡Ă¶ 100%' : 'RELAXED Ă”Ă‡Ă¶ 70% / 100%'}\r\n                    </button>\r\n                  ))}\r\n                </div>\r\n                <p className=\"muted\" style={{ fontSize: '0.8rem', marginTop: 8 }}>\r\n                  {MODE_LABELS[state.mode]}\r\n                </p>\r\n              </div>\r\n            </section>\r\n\r\n            {/* Ă”Ă¶Ă‡Ă”Ă¶Ă‡ â”œĂ«tape 4 Ă”Ă‡Ă¶ ECIES Ă”Ă¶Ă‡Ă”Ă¶Ă‡ */}\r\n            <section className=\"glass-panel stagger-in delay-2 sponsor-key-step\">\r\n              <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>\r\n                <div>\r\n                  <p className=\"step-plain\">â”œĂ«tape 5 Ă”Ă‡Ă¶ Clâ”œÂ® ECIES</p>\r\n                  <p className=\"muted step-meta\">secp256k1 + HKDF-SHA256 + AES-256-GCM â”¬Ă€ IV 96 bits</p>\r\n                </div>\r\n                {step4Done && <span className=\"status-chip ok\">Ă”Â£Ă  Prâ”œÂ¬te</span>}\r\n              </div>\r\n\r\n              {!state.keyPair && (\r\n                <button onClick={handleGenerateKeys} className=\"app-btn secondary fit-content\">\r\n                  Gâ”œÂ®nâ”œÂ®rer la paire de clâ”œÂ®s\r\n                </button>\r\n              )}\r\n\r\n              {state.keyPair && (\r\n                <div className=\"sponsor-key-grid\">\r\n                  <div>\r\n                    <p className=\"muted key-label\">Clâ”œÂ® publique Ă”Ă‡Ă¶ stockâ”œÂ®e on-chain</p>\r\n                    <div className=\"mono-box pub-key\">{state.keyPair.publicKeyHex}</div>\r\n                  </div>\r\n                  <div>\r\n                    <p className=\"muted key-label\">Clâ”œÂ® privâ”œÂ®e Ă”Ă‡Ă¶ garder hors ligne</p>\r\n                    <div className={`mono-box priv-key ${state.keySaved ? '' : 'is-blurred'}`}>\r\n                      {state.keyPair.privateKeyHex}\r\n                    </div>\r\n                    {!state.keySaved && (\r\n                      <p className=\"key-warning\">Ă”ĂœĂ¡Â´Â©Ă… Tâ”œÂ®lâ”œÂ®charge et sauvegarde cette clâ”œÂ® hors ligne.</p>\r\n                    )}\r\n                  </div>\r\n                  <div className=\"btn-row\">\r\n                    <button onClick={handleDownloadKey} className=\"app-btn warn\">\r\n                      Ă”Â¼Ă§ Tâ”œÂ®lâ”œÂ®charger la clâ”œÂ® privâ”œÂ®e\r\n                    </button>\r\n                    <button onClick={handleGenerateKeys} className=\"app-btn secondary\">\r\n                      Ă”Ă¥â•‘ Râ”œÂ®gâ”œÂ®nâ”œÂ®rer\r\n                    </button>\r\n                  </div>\r\n                </div>\r\n              )}\r\n            </section>\r\n\r\n            {/* Ă”Ă¶Ă‡Ă”Ă¶Ă‡ â”œĂ«tape 5 Ă”Ă‡Ă¶ Reward Ă”Ă¶Ă‡Ă”Ă¶Ă‡ */}\r\n            <section className=\"glass-panel stagger-in delay-3 sponsor-step\">\r\n              <p className=\"step-title\">â”œĂ«tape 6 Ă”Ă‡Ă¶ Râ”œÂ®compense USDT</p>\r\n\r\n              <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 12 }}>\r\n                <div>\r\n                  <p className=\"muted key-label\">Râ”œÂ®compense totale (USDT)</p>\r\n                  <input\r\n                    type=\"number\"\r\n                    min={1}\r\n                    placeholder=\"ex: 1000\"\r\n                    value={state.rewardUsdt}\r\n                    className=\"mono-box\"\r\n                    style={{ width: '100%', color: '#4ade80', outline: 'none', fontSize: '1.1rem' }}\r\n                    onChange={e => handleRewardChange(e.target.value)}\r\n                  />\r\n                </div>\r\n                {state.mode === 1 && (\r\n                  <div>\r\n                    <p className=\"muted key-label\">Reward Floor RELAXED sans C3 (USDT)</p>\r\n                    <input\r\n                      type=\"number\"\r\n                      min={1}\r\n                      value={state.rewardFloorUsdt}\r\n                      className=\"mono-box\"\r\n                      style={{ width: '100%', color: '#e2cfac', outline: 'none', fontSize: '1.1rem' }}\r\n                      onChange={e => setState(s => ({ ...s, rewardFloorUsdt: e.target.value }))}\r\n                    />\r\n                    <p className=\"muted\" style={{ fontSize: '0.78rem', marginTop: 4 }}>\r\n                      Calculâ”œÂ® automatiquement â”œĂ¡ 70% Ă”Ă‡Ă¶ modifiable\r\n                    </p>\r\n                  </div>\r\n                )}\r\n              </div>\r\n            </section>\r\n\r\n            {/* Ă”Ă¶Ă‡Ă”Ă¶Ă‡ â”œĂ«tape 6 Ă”Ă‡Ă¶ createBounty() Ă”Ă¶Ă‡Ă”Ă¶Ă‡ */}\r\n            <section className=\"glass-panel stagger-in delay-3 sponsor-step\">\r\n              <p className=\"step-title\">â”œĂ«tape 7 Ă”Ă‡Ă¶ Crâ”œÂ®er le Bounty</p>\r\n\r\n              {/* Râ”œÂ®capitulatif */}\r\n              <div style={{ background: 'rgba(11,22,36,0.5)', borderRadius: 12, padding: '14px 16px', marginBottom: 16, display: 'flex', flexDirection: 'column', gap: 8 }}>\r\n                <RecapRow label=\"WASM\"     value={step1Done ? 'Ă”Â£Ă  Uploadâ”œÂ®' : 'Ă”Ă˜Ă® Manquant'} ok={step1Done} />\r\n                <RecapRow label=\"Bitmaps\"  value={step2Done ? 'Ă”Â£Ă  A + B uploadâ”œÂ®s' : 'Ă”Ă˜Ă® Manquants'} ok={step2Done} />\r\n                <RecapRow label=\"Domaine\"  value={DOMAIN_LABELS[state.domain]} ok />\r\n                <RecapRow label=\"Mode\"     value={state.mode === 0 ? 'STRICT' : 'RELAXED'} ok />\r\n                <RecapRow label=\"ECIES\"    value={step4Done ? 'Ă”Â£Ă  Clâ”œÂ® sauvegardâ”œÂ®e' : state.keyPair ? 'Ă”ĂœĂ¡Â´Â©Ă… Clâ”œÂ® non sauvegardâ”œÂ®e' : 'Ă”Ă˜Ă® Manquante'} ok={step4Done} />\r\n                <RecapRow label=\"Reward\"   value={state.rewardUsdt ? `${state.rewardUsdt} USDT` : 'Ă”Ă˜Ă® Manquant'} ok={!!state.rewardUsdt} />\r\n              </div>\r\n\r\n              <button\r\n                onClick={handleCreateBounty}\r\n                className=\"app-btn primary\"\r\n                disabled={!allDone || isPending}\r\n                style={{ opacity: allDone ? 1 : 0.5 }}\r\n              >\r\n                {isPending ? 'En attente MetaMask...' : 'Crâ”œÂ®er le Bounty Ă”Ă‡Ă¶ Verrouiller USDT'}\r\n              </button>\r\n\r\n              {/* Statut Tx */}\r\n              {isSuccess && txHash && (\r\n                <div style={{ marginTop: 12 }}>\r\n                  <span className=\"status-chip ok\">Ă”Â£Ă  Bounty crâ”œÂ®â”œÂ®</span>\r\n                  <div className=\"mono-box\" style={{ marginTop: 8, color: '#4ade80' }}>\r\n                    Tx : {txHash}\r\n                  </div>\r\n                  <a\r\n                    href={`https://sepolia.etherscan.io/tx/${txHash}`}\r\n                    target=\"_blank\"\r\n                    rel=\"noreferrer\"\r\n                    className=\"app-btn secondary fit-content\"\r\n                    style={{ display: 'inline-block', marginTop: 8, textDecoration: 'none' }}\r\n                  >\r\n                    Voir sur Etherscan Ă”Ă¥Ă†\r\n                  </a>\r\n                </div>\r\n              )}\r\n\r\n              {isError && (\r\n                <p className=\"error-note\" style={{ marginTop: 8 }}>\r\n                  Ă”Ă˜Ă® {error?.message ?? 'Transaction â”œÂ®chouâ”œÂ®e'}\r\n                </p>\r\n              )}\r\n            </section>\r\n\r\n          </>\r\n        )}\r\n\r\n        {/* Mauvais râ”œÂ®seau */}\r\n        {isConnected && !isOnSepolia && (\r\n          <div className=\"glass-panel stagger-in network-warning\">\r\n            Changez vers le râ”œÂ®seau <strong>Sepolia</strong> dans MetaMask pour continuer\r\n          </div>\r\n        )}\r\n\r\n      </div>\r\n    </main>\r\n  )\r\n}\r\n\r\n// Ă”Ă¶Ă‡Ă”Ă¶Ă‡ Composant râ”œÂ®capitulatif Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡\r\n\r\nfunction RecapRow({ label, value, ok }: { label: string; value: string; ok: boolean }) {\r\n  return (\r\n    <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>\r\n      <span className=\"muted\" style={{ fontSize: '0.85rem' }}>{label}</span>\r\n      <span style={{ fontSize: '0.85rem', color: ok ? '#4ade80' : '#f87171', fontFamily: 'monospace' }}>\r\n        {value}\r\n      </span>\r\n    </div>\r\n  )\r\n}","usedDeprecatedRules":[]}]
